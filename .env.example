# Watchman Finance — Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to source control.

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=development

# ── QuickBooks Online ─────────────────────────────────────────────────────────
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_REDIRECT_URI=http://localhost:3000/api/integrations/quickbooks/callback
QBO_ENVIRONMENT=sandbox

# ── Watchman Integration Keys ─────────────────────────────────────────────────
# Shared secret for inbound events from Launch and Operations
WATCHMAN_INTEGRATION_SECRET=

# ── Internal ──────────────────────────────────────────────────────────────────
# Bootstrap admin — used only by scripts/bootstrap.cjs, never at runtime
BOOTSTRAP_EMAIL=
BOOTSTRAP_PASSWORD=
BOOTSTRAP_NAME=
