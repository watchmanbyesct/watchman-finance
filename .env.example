# Watchman Finance — Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to source control.

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=development

# ── External accounting OAuth (Intuit developer platform) ─────────────────────
ACCOUNTING_OAUTH_CLIENT_ID=
ACCOUNTING_OAUTH_CLIENT_SECRET=
ACCOUNTING_OAUTH_REDIRECT_URI=http://localhost:3000/api/integrations/accounting-oauth/callback
# If unset, set to 1 so redirect_uri = {current request origin}/api/integrations/accounting-oauth/callback (register that URL in the developer app).
ACCOUNTING_OAUTH_REDIRECT_USE_REQUEST_ORIGIN=

ACCOUNTING_OAUTH_ENVIRONMENT=sandbox

# Optional: webhook verifier token from the developer portal
ACCOUNTING_OAUTH_WEBHOOK_VERIFIER_TOKEN=

# ── Watchman Integration Keys ─────────────────────────────────────────────────
# Shared secret for inbound events from Launch and Operations
WATCHMAN_INTEGRATION_SECRET=

# ── Internal ──────────────────────────────────────────────────────────────────
# Bootstrap admin — used only by scripts/bootstrap.cjs, never at runtime
BOOTSTRAP_EMAIL=
BOOTSTRAP_PASSWORD=
BOOTSTRAP_NAME=
